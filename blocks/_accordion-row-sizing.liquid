{% doc %}
  Accordion row for Sizing — hidden when custom.size_guide metafield is blank.

  @example
  {% content_for 'block', type: '_accordion-row-sizing', id: 'sizing' %}
{% enddoc %}

{%- unless closest.product.metafields.custom.size_guide == blank -%}
  {%- capture row_children -%}
    <details class="details" {{ block.shopify_attributes }}>
      <summary class="details__header">
        Sizing
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
        <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="details-content">
        {{ closest.product.metafields.custom.size_guide | metafield_tag }}
      </div>
    </details>
  {%- endcapture -%}
  {%- render 'accordion-custom-component',
    children: row_children,
    open_by_default_on_desktop: false,
    open_by_default_on_mobile: false
  -%}
{%- endunless -%}

{% schema %}
{
  "name": "Sizing accordion",
  "tag": null
}
{% endschema %}
