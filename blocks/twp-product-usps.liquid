{% doc %}
  Renders a 2x2 grid of USP (unique selling point) items below the add-to-cart button.
  Each item has a configurable icon and label.

  @example
  {% content_for 'block', type: 'twp-product-usps', id: 'product-usps' %}
{% enddoc %}

{%- liquid
  assign usp_icons = block.settings.usp_1_icon | append: ',' | append: block.settings.usp_2_icon | append: ',' | append: block.settings.usp_3_icon | append: ',' | append: block.settings.usp_4_icon | split: ','
  assign usp_labels = block.settings.usp_1_label | append: '|' | append: block.settings.usp_2_label | append: '|' | append: block.settings.usp_3_label | append: '|' | append: block.settings.usp_4_label | split: '|'
-%}

<ul class="twp-product-usps" {{ block.shopify_attributes }}>
  {%- for label in usp_labels -%}
    {%- if label != blank -%}
      <li class="twp-product-usps__item">
        {%- liquid
          assign icon_name = usp_icons[forloop.index0]
          assign icon_file = 'icon-' | append: icon_name | append: '.svg'
          assign icon_svg = icon_file | inline_asset_content
        -%}
        {%- if icon_svg != blank -%}
          <span class="twp-product-usps__icon" aria-hidden="true">{{ icon_svg }}</span>
        {%- elsif icon_name != 'none' -%}
          {%- render 'icon-or-image', icon: icon_name, image_upload: blank, width: 12, class_name: 'twp-product-usps__icon' -%}
        {%- endif -%}
        <span class="twp-product-usps__label">{{- label -}}</span>
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul>

{% stylesheet %}
  .twp-product-usps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 16px;
    column-gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .twp-product-usps__item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.875rem;
    color: var(--color-foreground);
  }

  .twp-product-usps__icon {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    color: var(--color-foreground);
  }
{% endstylesheet %}

