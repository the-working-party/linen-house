{%- comment -%}
  layout-slider.liquid
  A horizontal carousel layout block that advances through child slides.
  Children must be _layout-slide blocks, which themselves accept any
  @theme or @app blocks.

  Companion runtime to the layout-slider.md spec in the Horizon component
  library (the-working-party/figma-horizon). See that spec for the
  authoritative definition of every setting and the test matrix.

  This block reuses Horizon's exported Slideshow class — the custom element
  JS is a thin wrapper that extends it. The markup produces the same ref
  structure that Slideshow expects: ref="scroller", ref="slideshowContainer",
  ref="slides[]" (on children), ref="previous", ref="next", ref="dots[]".
{%- endcomment -%}

{%- liquid
  assign slide_count = block.settings._layout_slide_count | default: 0

  # In the theme editor, always render so merchandisers can configure.
  # At runtime, skip rendering if there are no slides to show.
  # We use content_for 'blocks' which handles the child block count for us,
  # so we always render the wrapper and let CSS/JS handle empty states.
  assign should_render = true
-%}

{%- if should_render or request.design_mode -%}
  <div {{ block.shopify_attributes }} style="display: contents">
    <layout-slider-component
      role="region"
      aria-roledescription="carousel"
      aria-label="{{ block.settings.aria_label | default: 'Slider' }}"
      style="--layout-slider-gap: {{ block.settings.gap }}px; --slides-per-view-desktop: {{ block.settings.slides_per_view_desktop }}; --slides-per-view-mobile: {{ block.settings.slides_per_view_mobile }};"
      data-autoplay="{{ block.settings.autoplay }}"
      data-autoplay-interval="{{ block.settings.autoplay_interval }}"
      data-pause-on-hover="{{ block.settings.pause_on_hover }}"
      data-slides-per-view-desktop="{{ block.settings.slides_per_view_desktop }}"
      data-slides-per-view-mobile="{{ block.settings.slides_per_view_mobile }}"
      {%- if block.settings.loop %}
        infinite
      {%- endif %}
      {%- if block.settings.autoplay %}
        autoplay="{{ block.settings.autoplay_interval }}"
        aria-live="polite"
      {%- endif %}
    >
      <div ref="slideshowContainer" class="layout-slider__container">
        {%- if block.settings.navigation_style == 'arrows' or block.settings.navigation_style == 'arrows_and_dots' -%}
          <div class="layout-slider__arrows">
            <button
              class="layout-slider__arrow layout-slider__arrow--previous button button-unstyled"
              aria-label="{{ 'accessibility.slideshow_previous' | t | default: 'Previous slide' }}"
              on:click="/previous"
              ref="previous"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button
              class="layout-slider__arrow layout-slider__arrow--next button button-unstyled"
              aria-label="{{ 'accessibility.slideshow_next' | t | default: 'Next slide' }}"
              on:click="/next"
              ref="next"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {%- endif -%}

        <div
          ref="scroller"
          class="layout-slider__scroller"
          tabindex="-1"
        >
          {%- content_for 'blocks' -%}
        </div>
      </div>

      {%- if block.settings.navigation_style == 'dots' or block.settings.navigation_style == 'arrows_and_dots' -%}
        <div class="layout-slider__dots" role="tablist">
          {%- comment -%}
            Dots are generated by JavaScript at runtime based on the actual
            slide count. We render placeholder markup here for the theme
            editor preview; JS replaces it on connectedCallback.
          {%- endcomment -%}
        </div>
      {%- endif -%}
    </layout-slider-component>
  </div>
{%- endif -%}

{% stylesheet %}
  layout-slider-component {
    display: block;
    position: relative;
    width: 100%;
  }

  .layout-slider__container {
    position: relative;
    overflow: hidden;
  }

  .layout-slider__scroller {
    display: flex;
    gap: var(--layout-slider-gap, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .layout-slider__scroller::-webkit-scrollbar {
    display: none;
  }

  .layout-slider__scroller > * {
    scroll-snap-align: start;
    flex: 0 0 calc(
      (100% - var(--layout-slider-gap, 16px) * (var(--slides-per-view-desktop, 3) - 1)) /
      var(--slides-per-view-desktop, 3)
    );
  }

  @media screen and (max-width: 749px) {
    .layout-slider__scroller > * {
      flex: 0 0 calc(
        (100% - var(--layout-slider-gap, 16px) * (var(--slides-per-view-mobile, 1) - 1)) /
        var(--slides-per-view-mobile, 1)
      );
    }
  }

  /* Navigation arrows */
  .layout-slider__arrows {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    z-index: 2;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .layout-slider__arrow {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    cursor: pointer;
    transition: opacity 0.2s ease;
    color: inherit;
  }

  .layout-slider__arrow:hover {
    background: rgba(255, 255, 255, 1);
  }

  .layout-slider__arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .layout-slider__arrow--previous {
    margin-inline-start: 8px;
  }

  .layout-slider__arrow--next {
    margin-inline-end: 8px;
  }

  /* Dot indicators */
  .layout-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-block-start: 16px;
  }

  .layout-slider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .layout-slider__dot[aria-selected="true"] {
    background: rgba(0, 0, 0, 0.8);
  }

  .layout-slider__dot:hover {
    background: rgba(0, 0, 0, 0.5);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Layout Slider",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "label": "Slides per view (desktop)",
      "info": "Number of slides visible at once on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Slides per view (mobile)",
      "info": "Number of slides visible at once on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "info": "Space between slides in pixels",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "info": "Advance slides automatically",
      "default": false
    },
    {
      "type": "paragraph",
      "content": "Autoplay will pause when the user hovers over the slider or when any interactive element inside receives keyboard focus (WCAG 2.2.2).",
      "visible_if": "{{ block.settings.autoplay }}"
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval",
      "info": "Milliseconds between automatic advances",
      "min": 1000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "default": 5000,
      "visible_if": "{{ block.settings.autoplay }}"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "info": "Pause autoplay when the pointer is over the slider",
      "default": true,
      "visible_if": "{{ block.settings.autoplay }}"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "info": "Wrap around when reaching the last slide",
      "default": true
    },
    {
      "type": "select",
      "id": "navigation_style",
      "label": "Navigation style",
      "info": "How users move between slides",
      "options": [
        { "value": "none", "label": "No navigation" },
        { "value": "arrows", "label": "Arrows only" },
        { "value": "dots", "label": "Dots only" },
        { "value": "arrows_and_dots", "label": "Arrows and dots" }
      ],
      "default": "arrows_and_dots"
    }
  ],
  "blocks": [
    {
      "type": "_layout-slide"
    }
  ],
  "presets": [
    {
      "name": "Product carousel",
      "category": "Layout",
      "settings": {
        "slides_per_view_desktop": 4,
        "slides_per_view_mobile": 1,
        "gap": 16,
        "autoplay": false,
        "navigation_style": "arrows_and_dots",
        "loop": true
      }
    },
    {
      "name": "Hero slideshow",
      "category": "Layout",
      "settings": {
        "slides_per_view_desktop": 1,
        "slides_per_view_mobile": 1,
        "gap": 0,
        "autoplay": true,
        "autoplay_interval": 6000,
        "navigation_style": "dots",
        "loop": true
      }
    },
    {
      "name": "Testimonial carousel",
      "category": "Layout",
      "settings": {
        "slides_per_view_desktop": 3,
        "slides_per_view_mobile": 1,
        "gap": 24,
        "autoplay": true,
        "autoplay_interval": 7000,
        "navigation_style": "dots",
        "pause_on_hover": true,
        "loop": true
      }
    },
    {
      "name": "Logo bar",
      "category": "Layout",
      "settings": {
        "slides_per_view_desktop": 6,
        "slides_per_view_mobile": 2,
        "gap": 32,
        "autoplay": true,
        "autoplay_interval": 3000,
        "navigation_style": "none",
        "loop": true
      }
    }
  ]
}
{% endschema %}
