{%- liquid
  assign carousel_collection = section.settings.collection
  assign colour_option_names = 'color,colour,colore,farbe,couleur,cor'
  assign colour_option_list = colour_option_names | split: ','
-%}

{% capture children %}
  <div class="twp-collection-carousel">
    <div class="twp-collection-carousel__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="twp-collection-carousel__heading">{{- section.settings.heading | escape -}}</h2>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="twp-collection-carousel__cta button button--primary">
          {{- section.settings.button_label | escape -}}
          <span class="twp-collection-carousel__cta-icon" aria-hidden="true">
            {{- 'icon-arrow-right.svg' | inline_asset_content -}}
          </span>
        </a>
      {%- endif -%}
    </div>

    {%- if carousel_collection != blank -%}
      <div class="twp-collection-carousel__track">
        <div class="twp-collection-carousel__scroller">
          <ul class="twp-collection-carousel__list">
            {%- for product in carousel_collection.products limit: 8 -%}
              {%- liquid
                assign badge_label = nil
                for tag in product.tags
                  if tag contains 'badge:'
                    assign badge_label = tag | remove_first: 'badge:'
                    break
                  endif
                endfor

                assign swatch_colour_values = nil
                for option in product.options_with_values
                  assign option_name_lower = option.name | downcase
                  if colour_option_list contains option_name_lower
                    assign swatch_colour_values = option.values
                    break
                  endif
                endfor

                assign carousel_variant = product.selected_or_first_available_variant
              -%}
              <li class="twp-collection-carousel__item">
                <div class="twp-collection-carousel__card">
                  <div class="twp-collection-carousel__image-wrapper">
                    <a href="{{ product.url }}" class="twp-collection-carousel__image-link" aria-label="{{ product.title | escape }}">
                      {%- if product.featured_image -%}
                        {%- assign img_alt = product.featured_image.alt | default: product.title | escape -%}
                        {{
                          product.featured_image
                          | image_url: width: 800
                          | image_tag:
                            widths: '400, 600, 800',
                            sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 80vw',
                            alt: img_alt,
                            class: 'twp-collection-carousel__image',
                            loading: 'lazy'
                        }}
                      {%- else -%}
                        <div class="twp-collection-carousel__image-placeholder"></div>
                      {%- endif -%}
                    </a>
                    {%- if badge_label != nil -%}
                      <span class="twp-collection-carousel__badge">{{- badge_label -}}</span>
                    {%- endif -%}
                    {%- if product.available -%}
                      <div class="twp-collection-carousel__quick-add-overlay">
                        {%- if product.variants.size == 1 -%}
                          <product-form-component
                            on:submit="/handleSubmit"
                            data-product-id="{{ product.id }}"
                            data-quantity-default="1"
                          >
                            <form action="{{ routes.cart_add_url }}" method="post" data-type="add-to-cart-form">
                              <input type="hidden" name="id" value="{{ carousel_variant.id }}" ref="variantId">
                              <input type="hidden" name="quantity" value="1">
                              <button
                                type="submit"
                                class="twp-collection-carousel__quick-add-btn"
                                aria-label="{{ 'actions.add' | t }}: {{ product.title | escape }}"
                              >
                                {{- 'icon-cart.svg' | inline_asset_content -}}
                              </button>
                              <div ref="liveRegion" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
                            </form>
                          </product-form-component>
                        {%- else -%}
                          <a
                            href="{{ product.url }}"
                            class="twp-collection-carousel__quick-add-btn"
                            aria-label="{{ 'actions.choose' | t }}: {{ product.title | escape }}"
                            tabindex="-1"
                          >
                            {{- 'icon-cart.svg' | inline_asset_content -}}
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                  <div class="twp-collection-carousel__info">
                    {%- if swatch_colour_values != blank and swatch_colour_values.size > 0 -%}
                      {%- assign swatch_limit = 4 -%}
                      {%- assign swatch_overflow = swatch_colour_values.size | minus: swatch_limit -%}
                      <div class="twp-collection-carousel__swatches">
                        {%- for value in swatch_colour_values limit: swatch_limit -%}
                          {%- liquid
                            assign swatch_bg = ''
                            if value.swatch
                              if value.swatch.image
                                assign swatch_image_url = value.swatch.image | image_url: width: 64
                                assign swatch_bg = 'url(' | append: swatch_image_url | append: ') center / cover'
                              elsif value.swatch.color
                                assign swatch_bg = value.swatch.color
                              endif
                            else
                              assign swatch_handle = value | handleize
                              assign swatch_filename = 'swatch-' | append: swatch_handle | append: '.jpg'
                              assign swatch_asset = images[swatch_filename]
                              if swatch_asset
                                assign swatch_asset_url = swatch_asset | image_url: width: 64
                                assign swatch_bg = 'url(' | append: swatch_asset_url | append: ') center / cover'
                              else
                                assign swatch_bg = value | handleize | replace: '-', ''
                              endif
                            endif
                          -%}
                          <span
                            class="twp-collection-carousel__swatch"
                            style="{%- if swatch_bg contains 'url(' -%}background: {{ swatch_bg }};{%- else -%}background-color: {{ swatch_bg }};{%- endif -%}"
                            title="{{ value | escape }}"
                            aria-label="{{ value | escape }}"
                          ></span>
                        {%- endfor -%}
                        {%- if swatch_overflow > 0 -%}
                          <span class="twp-collection-carousel__swatch-overflow">+{{ swatch_overflow }}</span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                    <a href="{{ product.url }}" class="twp-collection-carousel__info-link">
                      <span class="twp-collection-carousel__vendor">{{- product.vendor | escape -}}</span>
                      <span class="twp-collection-carousel__title">{{- product.title | escape -}}</span>
                      {%- if product.type != blank -%}
                        <span class="twp-collection-carousel__type">{{- product.type | escape -}}</span>
                      {%- endif -%}
                      <span class="twp-collection-carousel__price">{{- product.price_min | money -}}</span>
                    </a>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
        <button class="twp-collection-carousel__arrow twp-collection-carousel__arrow--prev" aria-label="Scroll left" hidden>
          {{- 'icon-chevron-left.svg' | inline_asset_content -}}
        </button>
        <button class="twp-collection-carousel__arrow twp-collection-carousel__arrow--next" aria-label="Scroll right">
          {{- 'icon-chevron-right.svg' | inline_asset_content -}}
        </button>
      </div>
    {%- endif -%}
  </div>
{% endcapture %}

{% render 'section', section: section, children: children %}

{% stylesheet %}
  .twp-collection-carousel__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--gap-lg, 24px);
    margin-bottom: var(--gap-xl, 32px);
  }

  .twp-collection-carousel__heading {
    flex: 1;
    margin: 0;
    font-family: var(--font-primary--family);
    font-size: var(--font-h3--size);
    font-weight: var(--font-heading--weight);
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--color-foreground-heading);
  }

  .twp-collection-carousel__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--gap-xs, 8px);
    height: var(--height-buy-buttons, 40px);
    padding-inline: var(--padding-lg, 16px);
    border-radius: var(--buttons-radius, 64px);
    background-color: var(--color-button);
    color: var(--color-button-text);
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph-medium--size, 0.875rem);
    text-decoration: none;
    white-space: nowrap;
  }

  .twp-collection-carousel__cta-icon svg {
    width: 12px;
    height: auto;
    color: inherit;
  }

  .twp-collection-carousel__track {
    position: relative;
  }

  .twp-collection-carousel__scroller {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .twp-collection-carousel__scroller::-webkit-scrollbar {
    display: none;
  }

  .twp-collection-carousel__list {
    display: flex;
    gap: var(--gap-sm, 8px);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .twp-collection-carousel__item {
    flex: 0 0 calc(25% - var(--gap-sm, 8px) * 3 / 4);
    min-width: 240px;
  }

  .twp-collection-carousel__card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md, 16px);
    color: var(--color-foreground);
  }

  .twp-collection-carousel__image-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--media-radius, 12px);
  }

  .twp-collection-carousel__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .twp-collection-carousel__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .twp-collection-carousel__card:hover .twp-collection-carousel__image {
    transform: scale(1.03);
  }

  .twp-collection-carousel__image-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-background-secondary);
  }

  .twp-collection-carousel__badge {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding-inline: 12px;
    border-radius: var(--buttons-radius, 64px);
    background-color: var(--color-background-secondary);
    color: var(--color-foreground);
    font-size: 0.75rem;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
  }

  .twp-collection-carousel__quick-add-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 12px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .twp-collection-carousel__card:hover .twp-collection-carousel__quick-add-overlay,
  .twp-collection-carousel__card:focus-within .twp-collection-carousel__quick-add-overlay {
    opacity: 1;
  }

  .twp-collection-carousel__quick-add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--buttons-radius, 64px);
    background-color: var(--color-background);
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    text-decoration: none;
    flex-shrink: 0;
  }

  .twp-collection-carousel__quick-add-btn svg {
    width: 12px;
    height: auto;
  }

  .twp-collection-carousel__info {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md, 16px);
  }

  .twp-collection-carousel__swatches {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .twp-collection-carousel__swatch {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid rgb(0 0 0 / 0.15);
    flex-shrink: 0;
  }

  .twp-collection-carousel__swatch-overflow {
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.5);
    line-height: 20px;
  }

  .twp-collection-carousel__info-link {
    display: flex;
    flex-direction: column;
    gap: var(--component-spacing, 12px);
    text-decoration: none;
    color: inherit;
  }

  .twp-collection-carousel__vendor {
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.65));
  }

  .twp-collection-carousel__title {
    font-size: var(--font-paragraph-medium--size, 0.875rem);
    color: var(--color-foreground);
    line-height: 1.4;
  }

  .twp-collection-carousel__type {
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.65));
  }

  .twp-collection-carousel__price {
    font-size: 0.75rem;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.65));
    margin-top: 4px;
  }

  .twp-collection-carousel__arrow {
    position: absolute;
    top: 212px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--buttons-radius, 64px);
    background-color: var(--color-background);
    border: none;
    cursor: pointer;
    z-index: 1;
    color: var(--color-foreground);
  }

  .twp-collection-carousel__arrow svg {
    width: 12px;
    height: auto;
  }

  .twp-collection-carousel__arrow--prev {
    left: 12px;
  }

  .twp-collection-carousel__arrow--next {
    right: 12px;
  }

  @media screen and (max-width: 749px) {
    .twp-collection-carousel__item {
      flex: 0 0 calc(50% - 4px);
      min-width: 140px;
    }

    .twp-collection-carousel__heading {
      font-size: var(--font-h4--size);
    }

    .twp-collection-carousel__arrow {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.twp-collection-carousel__track').forEach((track) => {
    const scroller = track.querySelector('.twp-collection-carousel__scroller');
    const prevBtn = track.querySelector('.twp-collection-carousel__arrow--prev');
    const nextBtn = track.querySelector('.twp-collection-carousel__arrow--next');

    function scrollAmount() {
      const item = scroller.querySelector('.twp-collection-carousel__item');
      return item ? (item.offsetWidth + 8) * 2 : 500;
    }

    function updateArrows() {
      prevBtn.hidden = scroller.scrollLeft <= 0;
      nextBtn.hidden = scroller.scrollLeft >= scroller.scrollWidth - scroller.clientWidth - 1;
    }

    prevBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });

    scroller.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  });
{% endjavascript %}

{% schema %}
{
  "name": "Collection carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the collection"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection carousel",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
