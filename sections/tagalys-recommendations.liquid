{%- comment -%}
  Tagalys Recommendations Section.

  Universal recommendation widget usable on any template. Adds via theme
  editor (Customise > Add Section > Tagalys Recommendations).

  - When Tagalys is enabled: renders an SDK widget container; SDK populates
    Preact tiles. Visual parity with theme product card via assets/tagalys-skin.css.
  - When Tagalys is disabled: falls back to a fallback collection's products
    rendered via the theme's own `_product-card` block — so card markup
    matches the rest of the site exactly when Tagalys is off.

  Widget types:
    - smart_widget       — homepage / blog / marketing pages (no product context required)
    - similar_products   — PDP similar products
    - cross_selling      — PDP cross-sell (requires widget ID)
    - viewed_also_viewed — PDP viewed also viewed
    - bought_also_bought — PDP / cart bought also bought

  Product-based widgets auto-detect product.id from template context.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign widget_type = section.settings.widget_type
  assign widget_id = section.settings.widget_id
  assign product_limit = section.settings.product_limit
  assign fallback_collection = section.settings.fallback_collection
-%}

<div class="tagalys-recommendations-section" data-section-id="{{ section.id }}">
  {%- liquid
    assign tagalys_active = false
    if settings.tagalys_enabled and settings.tagalys_server_url != blank and settings.tagalys_api_key != blank
      assign tagalys_active = true
    endif
  -%}
  {%- if tagalys_active -%}
    {%- if heading != blank -%}
      <h2 class="tagalys-recommendations__heading">{{ heading }}</h2>
    {%- endif -%}
    <div
      class="tagalys-widget"
      data-product-based-widget
      data-tagalys-widget="{{ widget_type | replace: '_', '-' }}"
      data-tagalys-widget-opts-limit="{{ product_limit }}"
      {%- if widget_id != blank -%}
        data-widget-id="{{ widget_id }}"
      {%- endif -%}
      {%- if product and widget_type != 'smart_widget' -%}
        data-product-id="{{ product.id }}"
      {%- endif -%}
      {%- if heading != blank -%}
        data-widget-heading="{{ heading | escape }}"
      {%- endif -%}
    ></div>
  {%- elsif fallback_collection != blank -%}
    {%- if heading != blank -%}
      <h2 class="tagalys-recommendations__heading">{{ heading }}</h2>
    {%- endif -%}

    <ul class="tagalys-recommendations__grid product-grid grid gap-style">
      {%- for product in fallback_collection.products limit: product_limit -%}
        <li
          class="product-grid__item product-grid__item--{{ forloop.index0 }}"
          data-product-id="{{ product.id }}"
        >
          {% # theme-check-disable UniqueStaticBlockId %}
          {% content_for 'block', type: '_product-card', id: 'tagalys-fallback-product-card', closest.product: product %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{%- comment -%}
  whenTagalysReady polls until window.Tagalys exists (deferred SDK), then runs
  onTagalysReady which applies Tagalys.setConfiguration — same timing as cart upsell.
{%- endcomment -%}
{%- if tagalys_active -%}
  <script>
    (function () {
      window.TagalysCustomisations = window.TagalysCustomisations || {};

      TagalysCustomisations.initProductBasedWidget = function () {
        var Rec =
          window.Tagalys &&
          window.Tagalys.UIWidgets &&
          window.Tagalys.UIWidgets.Recommendations;
        if (!Rec || typeof Rec.init !== 'function') return;

        var recommendationId = {{ widget_id | json }};
        var productIds = {% if product -%}
          [{{ product.id | json }}]
        {%- else -%}
          []
        {%- endif -%};

        if (!recommendationId) return;

        Rec.init('[data-product-based-widget]', {
          recommendationId: recommendationId,
          productIds: productIds,
          templates: {
            product: {
              render: function (html, args) {
                var props = args.props;
                var product = props.product;
                var helpers = props.helpers;
        
                var navigateToProductDetailPage = (event) => {
                  helpers.navigateToProductDetailPage(event, product)
                }
        
                var productOptions = helpers.getTemplateOptions('product')
                var productLink = productOptions.productPageUrl(product)
        
                return html`
                  <div class="product" onClick=${navigateToProductDetailPage}>
                    <a
                      class="product-link"
                      href=${productLink}
                      target="_blank"
                    >
                      <span class="product-image-container">
                        ${product.featured_image ? (
                          html `<img
                            class="product-image"
                            data-src=${product.featured_image.src}
                            alt=${product.title}
                          />`
                        ) : null}
                      </span>
                      <div class="product-details">
                        <span class="product-name">${product.title} - template override!!!</span>
                        ${helpers.isStorefrontAPICallPending() ? (
                          html `<span class="skeleton-box"></span>`
                        ) : (
                          html `<span
                            class=${`product-prices${
                              helpers.isProductOnSale(
                                product.compare_at_price,
                                product.price
                              )
                                ? " discounted"
                                : " full-price"
                            }`}
                          >
                            ${helpers.isProductOnSale(
                              product.compare_at_price,
                              product.price
                            )
                              ? html`
                                  <span class="product-price-discounted"
                                    >${helpers.formatCurrency(product.price)}</span
                                  >
                                `
                              : null}
                            <span class="product-price-regular">
                              ${helpers.formatCurrency(
                                product.compare_at_price === null
                                  ? product.price
                                  : product.compare_at_price
                              )}
                            </span>
                          </span>`
                        )}
                      </div>
                    </a>
                  </div>
                `;
              },
            },
          },
        });
      };

      if (typeof whenTagalysReady !== 'function') return;
      whenTagalysReady(function () {
        TagalysCustomisations.initProductBasedWidget();
      });
    })();
  </script>
{%- endif -%}

{% stylesheet %}
  .tagalys-recommendations-section {
    container-type: inline-size;
  }
  .tagalys-recommendations__heading {
    margin: 0 0 1rem 0;
  }
  .tagalys-recommendations__grid {
    list-style: none;
    margin: 0;
    padding: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.tagalys_recommendations",
  "class": "section-wrapper tagalys-recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "widget_type",
      "label": "t:settings.tagalys_widget_type",
      "options": [
        { "value": "smart_widget", "label": "t:options.tagalys_smart_widget" },
        { "value": "similar_products", "label": "t:options.tagalys_similar_products" },
        { "value": "cross_selling", "label": "t:options.tagalys_cross_selling" },
        { "value": "viewed_also_viewed", "label": "t:options.tagalys_viewed_also_viewed" },
        { "value": "bought_also_bought", "label": "t:options.tagalys_bought_also_bought" }
      ],
      "default": "smart_widget",
      "info": "t:info.tagalys_widget_type_recommendations"
    },
    {
      "type": "text",
      "id": "widget_id",
      "label": "t:settings.tagalys_widget_id",
      "info": "t:info.tagalys_widget_id_recommendations"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:settings.tagalys_product_limit",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "t:settings.tagalys_fallback_collection",
      "info": "t:info.tagalys_fallback_collection"
    }
  ],
  "presets": [
    {
      "name": "t:names.tagalys_recommendations"
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
