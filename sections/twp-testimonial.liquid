
{%- liquid
  assign testimonial = section.settings.testimonial
  assign rating = 5
  assign content = blank
  assign author = blank

  if testimonial != blank
    assign rating_raw = testimonial.rating.value
    if rating_raw.rating != blank
      assign rating = rating_raw.rating | round
    else
      assign rating = rating_raw | round
    endif
    if rating == 0
      assign rating = 5
    endif
    assign content = testimonial.content.value
    assign author = testimonial.author.value
  endif

  if request.visual_preview_mode and testimonial == blank
    assign preview_mode = true
    assign content = '"Share a customer quote here that highlights the quality or experience of your products. Great testimonials build trust and inspire confidence."'
    assign author = 'Customer Name'
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--full-width testimonial color-{{ section.settings.color_scheme }} spacing-style"
  style="{%- render 'spacing-style', settings: section.settings %}"
>
  {%- if testimonial != blank or preview_mode -%}
    <div class="testimonial__inner">

      <div
        class="testimonial__stars"
        aria-label="{{ 'accessibility.rating' | t: rating: rating }}"
        role="img"
      >
        <svg
          class="visually-hidden"
          style="width: 0; height: 0;"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 32 32"
          role="presentation"
          aria-hidden="true"
        >
          <defs>
            <symbol viewBox="0 0 32 32" id="testimonial-star-{{ section.id }}">
              <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z" />
            </symbol>
          </defs>
        </svg>
        {%- assign rating_int = rating | round -%}
        {%- for i in (1..5) -%}
          <svg
            class="testimonial__star{% if i <= rating_int %} testimonial__star--filled{% endif %}"
            viewBox="0 0 32 32"
            role="presentation"
            aria-hidden="true"
          >
            <use href="#testimonial-star-{{ section.id }}"></use>
          </svg>
        {%- endfor -%}
      </div>

      {%- if content != blank -%}
        <p class="testimonial__content h5">{{ content }}</p>
      {%- endif -%}

      {%- if author != blank -%}
        <p class="testimonial__author">{{ author }}</p>
      {%- endif -%}

    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .testimonial {
    display: flex;
    justify-content: center;
  }

  .testimonial__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-2xl);
    max-width: 940px;
    width: 100%;
    text-align: center;
    padding-inline: var(--padding-xl);
  }

  .testimonial__stars {
    display: flex;
    gap: var(--gap-3xs);
    align-items: center;
  }

  .testimonial__star {
    width: 10px;
    height: 10px;
    fill: rgb(var(--color-foreground-rgb) / 0.2);
  }

  .testimonial__star--filled {
    fill: var(--color-foreground);
  }

  .testimonial__content {
    margin: 0;
  }

  .testimonial__author {
    margin: 0;
    font-size: var(--paragraph-large);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.testimonials",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "metaobject",
      "id": "testimonial",
      "label": "t:settings.testimonial",
      "metaobject_type": "testimonial"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "t:names.testimonials"
    }
  ]
}
{% endschema %}
