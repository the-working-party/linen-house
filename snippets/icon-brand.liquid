{% doc %}
  Renders a brand-specific inline SVG icon from assets.

  Resolves `icon-{settings.brand}-{name}.svg`. Both brand icon sets must exist
  in assets. Use string literals for `name` — dynamic values won't be found.

  @param {string} name - Icon name (e.g. 'close', 'search', 'bag')

  @example
  {%- render 'icon-brand', name: 'close' -%}
{% enddoc %}

