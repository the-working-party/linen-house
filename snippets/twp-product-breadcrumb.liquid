{% doc %}
  Renders a breadcrumb trail absolutely positioned over the product gallery.
  Builds Home → Collection → Product from the product's first collection.

  @param {product} product - The current product object

  @example
  {% render 'twp-product-breadcrumb', product: product %}
{% enddoc %}

{%- liquid
  assign collection = product.collections | first
-%}

<nav
  class="twp-product-breadcrumb"
  aria-label="{{ 'accessibility.breadcrumb' | t }}"
>
  <ol class="twp-product-breadcrumb__list">
    <li class="twp-product-breadcrumb__item">
      <a href="{{ routes.root_url }}" class="twp-product-breadcrumb__link">
        {{- 'accessibility.home' | t -}}
      </a>
      <span class="twp-product-breadcrumb__separator" aria-hidden="true">
        {{- 'icon-chevron-right.svg' | inline_asset_content -}}
      </span>
    </li>
    {%- if collection -%}
      <li class="twp-product-breadcrumb__item">
        <a href="{{ collection.url }}" class="twp-product-breadcrumb__link">
          {{- collection.title -}}
        </a>
        <span class="twp-product-breadcrumb__separator" aria-hidden="true">
          {{- 'icon-chevron-right.svg' | inline_asset_content -}}
        </span>
      </li>
    {%- endif -%}
    <li class="twp-product-breadcrumb__item">
      <span aria-current="page">{{- product.title -}}</span>
    </li>
  </ol>
</nav>

{% stylesheet %}
  .twp-product-breadcrumb {
    position: absolute;
    left: 32px;
    top: 30px;
    z-index: 2;
  }

  .twp-product-breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--navigation-extra-small);
    line-height: 1;
    letter-spacing: var(--navigation-letter-spacing);
  }

  .twp-product-breadcrumb__item {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .twp-product-breadcrumb__link {
    color: var(--color-foreground);
    text-decoration: none;
  }

  .twp-product-breadcrumb__link:hover {
    text-decoration: underline;
  }

  .twp-product-breadcrumb__separator {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 12px;
    height: 12px;
  }

  .twp-product-breadcrumb__separator svg {
    width: 4px;
    height: auto;
  }

  @media screen and (max-width: 749px) {
    .twp-product-breadcrumb {
      position: static;
      padding: var(--section-margin) var(--section-margin) 0 0;
    }
  }
{% endstylesheet %}
