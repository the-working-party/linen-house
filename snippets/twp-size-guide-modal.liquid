{% doc %}
  Size guide modal overlay. Opened by any element with
  [data-dialog-target="twp-size-guide-component"].

  Product-level content takes priority: if the product has a `custom.size_chart` metaobject
  assigned, its `content` field (rich text) is rendered. Falls back to the global
  `size_guide_page` Shopify page selected in the theme editor.

  @param {metaobject} [size_chart] - The product's custom.size_chart metaobject value.
  @param {page} [size_guide_page] - Fallback Shopify page rendered when size_chart is blank.

  @example
  {% render 'twp-size-guide-modal', size_chart: product.metafields.custom.size_chart.value, size_guide_page: size_guide_page %}
{% enddoc %}

<dialog-component id="twp-size-guide-component">
  <dialog
    class="twp-size-guide-modal dialog-modal"
    ref="dialog"
  >
    <div class="twp-size-guide-modal__header">
      <p class="twp-size-guide-modal__title">{{ 'products.size_guide.title' | t }}</p>
      <button
        type="button"
        class="button-unstyled twp-size-guide-modal__close"
        ref="closeButton"
        on:click="/closeDialog"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>
    <div class="twp-size-guide-modal__body rte">
      {%- if size_chart != blank -%}
        {{ size_chart.content | metafield_tag }}
      {%- elsif size_guide_page != blank -%}
        {{ size_guide_page.content }}
      {%- endif -%}
    </div>
  </dialog>
</dialog-component>

{% stylesheet %}
  .twp-size-guide-modal {
    padding: 0;
    border: none;
    overflow: hidden;
    box-shadow: 0 5px 30px rgb(0 0 0 / 0.12);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  .twp-size-guide-modal[open] {
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 750px) {
    .twp-size-guide-modal {
      position: fixed;
      inset: 0 0 0 auto;
      margin: 0;
      width: 500px;
      max-width: 100%;
      height: 100%;
      max-height: 100%;
      border-radius: var(--style-border-radius-popover) 0 0 var(--style-border-radius-popover);
    }

    .twp-size-guide-modal[open] {
      animation: twpSizeGuideSlideInRight var(--animation-speed) var(--animation-easing) forwards;
    }

    .twp-size-guide-modal.dialog-closing {
      animation: twpSizeGuideSlideOutRight var(--animation-speed) var(--animation-easing) forwards;
    }
  }

  @media screen and (max-width: 749px) {
    .twp-size-guide-modal {
      position: fixed;
      margin: auto 0 0;
      width: 100%;
      max-width: 100%;
      max-height: 80svh;
      border-radius: var(--style-border-radius-popover) var(--style-border-radius-popover) 0 0;
    }

    .twp-size-guide-modal[open] {
      animation: twpSizeGuideSlideUp var(--animation-speed) var(--animation-easing) forwards;
    }

    .twp-size-guide-modal.dialog-closing {
      animation: twpSizeGuideSlideDown var(--animation-speed) var(--animation-easing) forwards;
    }
  }

  .twp-size-guide-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 24px 16px;
    flex-shrink: 0;
  }

  .twp-size-guide-modal__title {
    margin: 0;
    font-size: var(--font-paragraph-large--size, 1rem);
    font-weight: var(--font-paragraph--weight, 400);
    letter-spacing: 0.2px;
    color: var(--color-foreground);
  }

  .twp-size-guide-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--color-foreground);
    cursor: pointer;
  }

  .twp-size-guide-modal__close svg {
    width: 16px;
    height: 16px;
  }

  .twp-size-guide-modal__body {
    padding: 24px;
    overflow-y: auto;
    flex: 1;
  }

  .twp-size-guide-modal__body h2,
  .twp-size-guide-modal__body h3 {
    font-size: var(--font-paragraph-small--size, 0.75rem);
    font-weight: var(--font-paragraph--weight, 400);
    letter-spacing: 0.2px;
    margin: 32px 0 16px;
  }

  .twp-size-guide-modal__body h2:first-child,
  .twp-size-guide-modal__body h3:first-child {
    margin-top: 0;
  }

  .twp-size-guide-modal__body table {
    width: 100%;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .twp-size-guide-modal__body thead,
  .twp-size-guide-modal__body tbody,
  .twp-size-guide-modal__body tr {
    display: table;
    width: 100%;
    table-layout: fixed;
  }

  .twp-size-guide-modal__body th,
  .twp-size-guide-modal__body td {
    height: 40px;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
    white-space: nowrap;
    font-size: var(--font-paragraph-small--size, 0.75rem);
    font-weight: var(--font-paragraph--weight, 400);
    letter-spacing: 0.2px;
    text-align: center;
  }

  .twp-size-guide-modal__body th:first-child,
  .twp-size-guide-modal__body td:first-child {
    text-align: left;
    font-size: var(--font-paragraph-size, 0.875rem);
    min-width: 120px;
  }

  .twp-size-guide-modal__body th {
    font-size: var(--font-paragraph-size, 0.875rem);
  }

  .twp-size-guide-modal__body p {
    font-size: var(--font-paragraph-small--size, 0.75rem);
    line-height: var(--font-paragraph-line-height, 1.5);
    letter-spacing: 0.2px;
    margin-top: 24px;
  }

  @keyframes twpSizeGuideSlideInRight {
    from { opacity: 0; transform: translateX(100%); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes twpSizeGuideSlideOutRight {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(100%); }
  }

  @keyframes twpSizeGuideSlideUp {
    from { opacity: 0; transform: translateY(100%); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes twpSizeGuideSlideDown {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(100%); }
  }
{% endstylesheet %}
