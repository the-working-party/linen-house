{% doc %}
  Renders the animated add-to-cart success icon.

  Contains a checkmark-burst SVG with the CSS class structure expected by
  base.css — `.ring`, `.check`, and `.tick`.
  Must be rendered inside `.add-to-cart-button .svg-wrapper`.

  @example
  {%- render 'icon-atc-burst' -%}
{% enddoc %}

<svg
  class="checkmark-burst"
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle class="ring" cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1"/>
  <circle class="check" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
  <path
    class="tick"
    d="M7.5 12.5L10.5 15.5L16.5 9"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
