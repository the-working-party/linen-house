{% doc %}
  Supplementary JSON-LD structured data for product pages.
  Outputs BreadcrumbList and additional Product properties
  (color, material, care instructions) not covered by Shopify's
  built-in structured_data filter.

  @param {product} product - The current product object

  @example
  {% render 'twp-product-schema', product: product %}
{% enddoc %}

{%- liquid
  assign collection = product.collections | first
  assign current_variant = product.selected_or_first_available_variant

  assign colour_option_names = 'color,colour,colore,farbe,couleur,cor'
  assign colour_option_list = colour_option_names | split: ','
  assign colour_index = nil
  for opt in product.options_with_values
    assign opt_name_lower = opt.name | downcase
    if colour_option_list contains opt_name_lower
      assign colour_index = forloop.index0
      break
    endif
  endfor
  if colour_index != nil and current_variant != blank
    assign product_colour = current_variant.options[colour_index]
  endif

  assign product_material = product.metafields.custom.material
  assign product_care = product.metafields.custom.care_instructions.value
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'accessibility.home' | t | json }},
      "item": {{ shop.url | json }}
    }
    {%- if collection -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": {{ shop.url | append: collection.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": {{ shop.url | append: product.url | json }}
    }
    {%- else -%},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": {{ shop.url | append: product.url | json }}
    }
    {%- endif -%}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "url": {{ shop.url | append: product.url | json }}
  {%- if product_colour -%},
  "color": {{ product_colour | json }}
  {%- endif -%}
  {%- if product_material != blank -%},
  "material": {{ product_material | json }}
  {%- endif -%}
  {%- if product_care != blank -%},
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Care Instructions",
      "value": {{ product_care.label | json }}
    }
  ]
  {%- endif -%}
}
</script>
